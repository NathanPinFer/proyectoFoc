<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.proyectoFoc.controller.CambiarPasswordController"
           alignment="CENTER"
           style="-fx-background-color: rgba(0,0,0,0.8);">

    <VBox spacing="25" maxWidth="500" alignment="CENTER"
          style="-fx-background-color: white; -fx-padding: 40; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 30, 0, 0, 10);">
        
        <!-- Icono y título -->
        <VBox spacing="15" alignment="CENTER">
            <Label text="🔒" style="-fx-font-size: 60px;"/>
            <Label text="Cambio de Contraseña Obligatorio" wrapText="true" alignment="CENTER"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
            <Label text="Por seguridad, debes cambiar tu contraseña temporal antes de continuar" 
                   wrapText="true" alignment="CENTER"
                   style="-fx-font-size: 14px; -fx-text-fill: #7F8C8D; -fx-padding: 0 20 0 20;"/>
        </VBox>

        <!-- Formulario -->
        <VBox spacing="15">
            <!-- Contraseña actual -->
            <VBox spacing="8">
                <Label text="Contraseña Actual *" style="-fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                <PasswordField fx:id="passwordActualField" promptText="Ingresa tu contraseña temporal"
                              style="-fx-padding: 12 15; -fx-border-color: #ECF0F1; -fx-border-width: 2px; -fx-border-radius: 10px; -fx-background-radius: 10px; -fx-font-size: 14px;"/>
            </VBox>

            <!-- Nueva contraseña -->
            <VBox spacing="8">
                <Label text="Nueva Contraseña *" style="-fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                <PasswordField fx:id="passwordNuevaField" promptText="Mínimo 6 caracteres"
                              style="-fx-padding: 12 15; -fx-border-color: #ECF0F1; -fx-border-width: 2px; -fx-border-radius: 10px; -fx-background-radius: 10px; -fx-font-size: 14px;"/>
            </VBox>

            <!-- Confirmar contraseña -->
            <VBox spacing="8">
                <Label text="Confirmar Nueva Contraseña *" style="-fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                <PasswordField fx:id="passwordConfirmarField" promptText="Repite la nueva contraseña"
                              style="-fx-padding: 12 15; -fx-border-color: #ECF0F1; -fx-border-width: 2px; -fx-border-radius: 10px; -fx-background-radius: 10px; -fx-font-size: 14px;"/>
            </VBox>
        </VBox>

        <!-- Mensaje de error -->
        <Label fx:id="errorLabel" wrapText="true" alignment="CENTER"
               style="-fx-text-fill: #E74C3C; -fx-font-size: 13px; -fx-padding: 10; -fx-background-color: rgba(231,76,60,0.1); -fx-background-radius: 8px;"
               visible="false" managed="false"/>

        <!-- Requisitos de contraseña -->
        <VBox spacing="8" style="-fx-background-color: #F8F9FA; -fx-padding: 15; -fx-background-radius: 8px;">
            <Label text="📋 Requisitos de la contraseña:" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #2C3E50;"/>
            <Label text="• Mínimo 6 caracteres" style="-fx-font-size: 11px; -fx-text-fill: #7F8C8D;"/>
            <Label text="• Se recomienda usar mayúsculas, minúsculas y números" style="-fx-font-size: 11px; -fx-text-fill: #7F8C8D;"/>
        </VBox>

        <!-- Botón -->
        <Button text="Cambiar Contraseña" onAction="#cambiarPassword" maxWidth="Infinity"
                style="-fx-background-color: linear-gradient(to bottom right, #3498DB, #2980B9); -fx-text-fill: white; -fx-padding: 15 30; -fx-background-radius: 10px; -fx-cursor: hand; -fx-font-size: 15px; -fx-font-weight: bold;">
            <font><Font name="System Bold" size="15"/></font>
        </Button>

        <!-- Nota -->
        <Label text="⚠️ No podrás cerrar esta ventana hasta cambiar tu contraseña" 
               wrapText="true" alignment="CENTER"
               style="-fx-font-size: 11px; -fx-text-fill: #E74C3C; -fx-font-style: italic;"/>
    </VBox>

</StackPane>
