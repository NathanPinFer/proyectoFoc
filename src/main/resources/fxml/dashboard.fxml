<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx"
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="com.proyectoFoc.controller.DashboardController">

    <BorderPane styleClass="main-container">

        <!-- SIDEBAR -->
        <left>
            <VBox styleClass="sidebar" prefWidth="260">
                <VBox styleClass="logo" alignment="CENTER" spacing="10">
                    <Label text="🏨" style="-fx-font-size: 48px;" />
                    <Label text="Hotel Manager" styleClass="logo-text">
                        <font>
                            <Font name="System Bold" size="24" />
                        </font>
                    </Label>
                </VBox>

                <VBox styleClass="menu" spacing="5" VBox.vgrow="ALWAYS">
                    <Button styleClass="menu-item, active">
                        <graphic>
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="📊" style="-fx-font-size: 22px;" />
                                <Label text="Dashboard" />
                            </HBox>
                        </graphic>
                    </Button>

                    <Button styleClass="menu-item" onAction="#navegarReservas">
                        <graphic>
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="📅" style="-fx-font-size: 22px;" />
                                <Label text="Reservas" />
                            </HBox>
                        </graphic>
                    </Button>

                    <Button styleClass="menu-item" onAction="#navegarClientes">
                        <graphic>
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="👥" style="-fx-font-size: 22px;" />
                                <Label text="Clientes" />
                            </HBox>
                        </graphic>
                    </Button>

                    <Button styleClass="menu-item" onAction="#navegarHabitaciones">
                        <graphic>
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="🛏️" style="-fx-font-size: 22px;" />
                                <Label text="Habitaciones" />
                            </HBox>
                        </graphic>
                    </Button>

                    <Button fx:id="btnEmpleados" styleClass="menu-item" onAction="#navegarEmpleados">
                        <graphic>
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="👔" style="-fx-font-size: 22px;" />
                                <Label text="Empleados" />
                            </HBox>
                        </graphic>
                    </Button>

                    <Region VBox.vgrow="ALWAYS" />

                    <Button styleClass="menu-item" onAction="#cerrarSesion">
                        <graphic>
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="🚪" style="-fx-font-size: 22px;" />
                                <Label text="Cerrar Sesión" />
                            </HBox>
                        </graphic>
                    </Button>
                </VBox>
            </VBox>
        </left>

        <center>
            <VBox styleClass="main-content" spacing="20">
                <padding>
                    <Insets top="30" right="30" bottom="30" left="30" />
                </padding>

                <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="20">
                    <Label text="Panel Principal" styleClass="topbar-title">
                        <font>
                            <Font name="System Bold" size="28" />
                        </font>
                    </Label>
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox alignment="CENTER" spacing="12">
                        <Button text="◀" styleClass="btn-primary" onAction="#mesAnterior" />
                        <Label fx:id="lblMesAnio" text="Marzo 2026"
                            style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-min-width: 150px; -fx-alignment: center;" />
                        <Button text="▶" styleClass="btn-primary" onAction="#mesSiguiente" />
                    </HBox>
                </HBox>

                <HBox spacing="25" alignment="CENTER_LEFT">
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Pane
                            style="-fx-min-width: 20px; -fx-min-height: 20px; -fx-background-radius: 4; -fx-background-color: #27ae60;" />
                        <Label text="Check-in hoy" style="-fx-font-size: 13px;" />
                    </HBox>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Pane
                            style="-fx-min-width: 20px; -fx-min-height: 20px; -fx-background-radius: 4; -fx-background-color: #2980b9;" />
                        <Label text="En curso" style="-fx-font-size: 13px;" />
                    </HBox>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Pane
                            style="-fx-min-width: 20px; -fx-min-height: 20px; -fx-background-radius: 4; -fx-background-color: #e67e22;" />
                        <Label text="Check-out hoy" style="-fx-font-size: 13px;" />
                    </HBox>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Pane
                            style="-fx-min-width: 20px; -fx-min-height: 20px; -fx-background-radius: 4; -fx-background-color: #8e44ad;" />
                        <Label text="Reserva futura" style="-fx-font-size: 13px;" />
                    </HBox>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Pane
                            style="-fx-min-width: 20px; -fx-min-height: 20px; -fx-background-radius: 4; -fx-background-color: #95a5a6;" />
                        <Label text="Finalizada" style="-fx-font-size: 13px;" />
                    </HBox>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Pane
                            style="-fx-min-width: 20px; -fx-min-height: 20px; -fx-background-radius: 4; -fx-background-color: #e74c3c;" />
                        <Label text="No-show" style="-fx-font-size: 13px;" />
                    </HBox>
                </HBox>


                <HBox spacing="20" VBox.vgrow="ALWAYS">

                    <VBox HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" spacing="0"
                        style="-fx-background-color: white; -fx-background-radius: 15;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 4);">

                        <!-- FILA SUPERIOR: esquina fija + cabecera días -->
                        <HBox spacing="0">
                            <Pane fx:id="paneEsquina" minWidth="130" maxWidth="130" minHeight="36"
                                maxHeight="36"
                                style="-fx-background-color: #34495E; -fx-border-color: #2C3E50; -fx-border-width: 0 1 1 0;" />
                            <ScrollPane fx:id="scrollDias" HBox.hgrow="ALWAYS"
                                fitToHeight="true" fitToWidth="false"
                                hbarPolicy="NEVER" vbarPolicy="NEVER"
                                style="-fx-background: transparent; -fx-background-color: transparent;">
                                <GridPane fx:id="gridDias" style="-fx-background-color: #F8F9FA;" />
                            </ScrollPane>
                        </HBox>

                        <!-- FILA INFERIOR: habitaciones fijas + celdas -->
                        <HBox spacing="0" VBox.vgrow="ALWAYS">
                            <ScrollPane fx:id="scrollHabs"
                                fitToWidth="true" fitToHeight="false"
                                hbarPolicy="NEVER" vbarPolicy="NEVER"
                                minWidth="130" maxWidth="130"
                                style="-fx-background: transparent; -fx-background-color: transparent;">
                                <GridPane fx:id="gridHabitaciones"
                                    style="-fx-background-color: #34495E;" />
                            </ScrollPane>
                            <ScrollPane fx:id="scrollCeldas" HBox.hgrow="ALWAYS"
                                fitToWidth="false" fitToHeight="false"
                                hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED"
                                style="-fx-background: white; -fx-background-color: white;">
                                <GridPane fx:id="gridCeldas" style="-fx-background-color: white;" />
                            </ScrollPane>
                        </HBox>
                    </VBox>

                    <!-- PANEL DETALLE -->
                    <VBox fx:id="panelDetalle" minWidth="300" maxWidth="300"
                        managed="false" visible="false"
                        styleClass="clientes-table-container">
                        <padding>
                            <Insets top="20" right="20" bottom="20" left="20" />
                        </padding>

                        <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding: 0 0 20 0;">
                            <Label fx:id="lblDetalleTitulo" text="Detalle reserva"
                                style="-fx-font-size: 20px; -fx-font-weight: bold;"
                                HBox.hgrow="ALWAYS" />
                            <Button text="✕" styleClass="btn-close" onAction="#cerrarDetalle" />
                        </HBox>

                        <Label fx:id="lblDetalleEstado" text="" style="-fx-padding: 0 0 8 0;" />

                        <VBox spacing="18" style="-fx-padding: 12 0 0 0;">
                            <VBox spacing="6">
                                <Label text="HABITACIÓN" styleClass="form-label" />
                                <Label fx:id="lblDetalleHabitacion" text=""
                                    style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                                <Label fx:id="lblDetalleTipoHab" text=""
                                    style="-fx-font-size: 13px; -fx-text-fill: #7F8C8D;" />
                            </VBox>

                            <VBox spacing="6">
                                <Label text="HUÉSPED" styleClass="form-label" />
                                <Label fx:id="lblDetalleCliente" text=""
                                    style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                                <Label fx:id="lblDetalleVip" text=""
                                    style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #F39C12;" />
                            </VBox>

                            <VBox spacing="6">
                                <Label text="FECHAS" styleClass="form-label" />
                                <Label fx:id="lblDetalleFechaEntrada" text=""
                                    style="-fx-font-size: 14px;" />
                                <Label fx:id="lblDetalleFechaSalida" text=""
                                    style="-fx-font-size: 14px;" />
                                <Label fx:id="lblDetalleNoches" text=""
                                    style="-fx-font-size: 13px; -fx-text-fill: #7F8C8D;" />
                            </VBox>

                            <VBox spacing="6">
                                <Label text="IMPORTE" styleClass="form-label" />
                                <Label fx:id="lblDetallePrecioNoche" text=""
                                    style="-fx-font-size: 14px;" />
                                <Label fx:id="lblDetalleSubtotal" text=""
                                    style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                            </VBox>
                        </VBox>
                    </VBox>

                </HBox>
            </VBox>
        </center>
    </BorderPane>
</StackPane>