<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.proyectoFoc.controller.ClienteController">

    <!-- CONTENEDOR PRINCIPAL -->
    <BorderPane styleClass="main-container">
        
        <!-- SIDEBAR -->
        <left>
            <VBox styleClass="sidebar" prefWidth="260">
                <!-- Logo -->
                <VBox styleClass="logo" alignment="CENTER" spacing="10">
                    <Label text="🏨" style="-fx-font-size: 48px;"/>
                    <Label text="Hotel Manager" styleClass="logo-text">
                        <font><Font name="System Bold" size="24"/></font>
                    </Label>
                </VBox>

                <!-- Menú de navegación -->
                <VBox styleClass="menu" spacing="5" VBox.vgrow="ALWAYS">
                    <Button styleClass="menu-item" onAction="#volverDashboard">
                        <graphic>
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="📊" style="-fx-font-size: 22px;"/>
                                <Label text="Dashboard"/>
                            </HBox>
                        </graphic>
                    </Button>

                    <Button styleClass="menu-item">
                        <graphic>
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="📅" style="-fx-font-size: 22px;"/>
                                <Label text="Reservas"/>
                            </HBox>
                        </graphic>
                    </Button>

                    <Button styleClass="menu-item, active">
                        <graphic>
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="👥" style="-fx-font-size: 22px;"/>
                                <Label text="Clientes"/>
                            </HBox>
                        </graphic>
                    </Button>

                    <Button styleClass="menu-item">
                        <graphic>
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="🛏️" style="-fx-font-size: 22px;"/>
                                <Label text="Habitaciones"/>
                            </HBox>
                        </graphic>
                    </Button>

                    <Button styleClass="menu-item">
                        <graphic>
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="🧾" style="-fx-font-size: 22px;"/>
                                <Label text="Facturación"/>
                            </HBox>
                        </graphic>
                    </Button>

                    <Button styleClass="menu-item">
                        <graphic>
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="👔" style="-fx-font-size: 22px;"/>
                                <Label text="Empleados"/>
                            </HBox>
                        </graphic>
                    </Button>

                    <Region VBox.vgrow="ALWAYS"/>

                    <Button styleClass="menu-item" onAction="#cerrarSesion">
                        <graphic>
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label text="🚪" style="-fx-font-size: 22px;"/>
                                <Label text="Cerrar Sesión"/>
                            </HBox>
                        </graphic>
                    </Button>
                </VBox>
            </VBox>
        </left>

        <!-- CONTENIDO PRINCIPAL -->
        <center>
            <VBox styleClass="main-content" spacing="30">
                <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

                <!-- TOPBAR -->
                <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="20">
                    <Label text="Gestión de Clientes" styleClass="topbar-title">
                        <font><Font name="System Bold" size="28"/></font>
                    </Label>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="➕ Nuevo Cliente" styleClass="btn-primary" onAction="#abrirModalNuevo"/>
                </HBox>

                <!-- ESTADÍSTICAS -->
                <GridPane styleClass="stats-bar" hgap="15" vgap="15">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                    </columnConstraints>

                    <VBox styleClass="stat-mini" alignment="CENTER" spacing="5" GridPane.columnIndex="0">
                        <Label fx:id="totalClientesLabel" text="0" styleClass="stat-mini-value">
                            <font><Font name="System Bold" size="28"/></font>
                        </Label>
                        <Label text="Total Clientes" styleClass="stat-mini-label"/>
                    </VBox>

                    <VBox styleClass="stat-mini" alignment="CENTER" spacing="5" GridPane.columnIndex="1">
                        <Label fx:id="clientesVIPLabel" text="0" styleClass="stat-mini-value">
                            <font><Font name="System Bold" size="28"/></font>
                        </Label>
                        <Label text="Clientes VIP" styleClass="stat-mini-label"/>
                    </VBox>

                    <VBox styleClass="stat-mini" alignment="CENTER" spacing="5" GridPane.columnIndex="2">
                        <Label fx:id="clientesRegularesLabel" text="0" styleClass="stat-mini-value">
                            <font><Font name="System Bold" size="28"/></font>
                        </Label>
                        <Label text="Clientes Regulares" styleClass="stat-mini-label"/>
                    </VBox>

                    <VBox styleClass="stat-mini" alignment="CENTER" spacing="5" GridPane.columnIndex="3">
                        <Label fx:id="clientesNuevosHoyLabel" text="0" styleClass="stat-mini-value">
                            <font><Font name="System Bold" size="28"/></font>
                        </Label>
                        <Label text="Nuevos Hoy" styleClass="stat-mini-label"/>
                    </VBox>
                </GridPane>

                <!-- BARRA DE BÚSQUEDA -->
                <HBox styleClass="search-bar" spacing="15" alignment="CENTER_LEFT">
                    <TextField fx:id="buscarField" promptText="🔍 Buscar por nombre, DNI, email..." 
                              styleClass="search-input" HBox.hgrow="ALWAYS"
                              onKeyReleased="#buscarClientes"/>
                    <Button text="Buscar" styleClass="btn-search" onAction="#buscarClientes"/>
                </HBox>

                <!-- TABLA DE CLIENTES -->
                <VBox fx:id="tableContainer" styleClass="clientes-table-container" VBox.vgrow="ALWAYS">
                    <HBox styleClass="table-header">
                        <Label text="Lista de Clientes" styleClass="table-title">
                            <font><Font name="System Bold" size="18"/></font>
                        </Label>
                    </HBox>

                    <TableView fx:id="clientesTable">
                        <columns>
                            <TableColumn fx:id="nombreColumn" text="CLIENTE" prefWidth="250"/>
                            <TableColumn fx:id="dniColumn" text="DNI" prefWidth="120"/>
                            <TableColumn fx:id="telefonoColumn" text="TELÉFONO" prefWidth="150"/>
                            <TableColumn fx:id="ciudadColumn" text="CIUDAD" prefWidth="130"/>
                            <TableColumn fx:id="reservasColumn" text="RESERVAS" prefWidth="100"/>
                            <TableColumn fx:id="estadoColumn" text="ESTADO" prefWidth="120"/>
                            <TableColumn fx:id="accionesColumn" text="ACCIONES" prefWidth="180"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>

                    <!-- PAGINACIÓN -->
                    <HBox fx:id="paginacionContainer" styleClass="pagination" alignment="CENTER" spacing="10">
                        <padding><Insets top="25" bottom="25"/></padding>
                    </HBox>
                </VBox>
            </VBox>
        </center>
    </BorderPane>

    <!-- MODAL DE FORMULARIO (CREAR/EDITAR) -->
    <StackPane fx:id="modalFormContainer" visible="false" managed="false" 
               style="-fx-background-color: rgba(0,0,0,0.6);">
        <VBox styleClass="modal-content" maxWidth="700" maxHeight="-Infinity">
            <!-- Header -->
            <HBox styleClass="modal-header" alignment="CENTER_LEFT">
                <Label fx:id="modalFormTitle" text="Nuevo Cliente" styleClass="modal-title">
                    <font><Font name="System Bold" size="24"/></font>
                </Label>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="×" styleClass="btn-close" onAction="#cerrarModalForm">
                    <font><Font size="28"/></font>
                </Button>
            </HBox>

            <!-- Formulario -->
            <ScrollPane fitToWidth="true" style="-fx-background-color: white;">
                <VBox spacing="20">
                    <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>

                    <GridPane hgap="15" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>

                        <VBox spacing="8" GridPane.columnIndex="0">
                            <Label text="Nombre *" styleClass="form-label"/>
                            <TextField fx:id="nombreField" promptText="Nombre del cliente" styleClass="form-input"/>
                        </VBox>

                        <VBox spacing="8" GridPane.columnIndex="1">
                            <Label text="Apellidos *" styleClass="form-label"/>
                            <TextField fx:id="apellidosField" promptText="Apellidos del cliente" styleClass="form-input"/>
                        </VBox>
                    </GridPane>

                    <GridPane hgap="15" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>

                        <VBox spacing="8" GridPane.columnIndex="0">
                            <Label text="DNI/NIE *" styleClass="form-label"/>
                            <TextField fx:id="dniField" promptText="12345678A" styleClass="form-input"/>
                        </VBox>

                        <VBox spacing="8" GridPane.columnIndex="1">
                            <Label text="Teléfono *" styleClass="form-label"/>
                            <TextField fx:id="telefonoField" promptText="+34 600 000 000" styleClass="form-input"/>
                        </VBox>
                    </GridPane>

                    <VBox spacing="8">
                        <Label text="Email *" styleClass="form-label"/>
                        <TextField fx:id="emailField" promptText="cliente@ejemplo.com" styleClass="form-input"/>
                    </VBox>

                    <VBox spacing="8">
                        <Label text="Dirección" styleClass="form-label"/>
                        <TextField fx:id="direccionField" promptText="Calle, número, piso..." styleClass="form-input"/>
                    </VBox>

                    <GridPane hgap="15" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>

                        <VBox spacing="8" GridPane.columnIndex="0">
                            <Label text="Ciudad" styleClass="form-label"/>
                            <TextField fx:id="ciudadField" promptText="Madrid" styleClass="form-input"/>
                        </VBox>

                        <VBox spacing="8" GridPane.columnIndex="1">
                            <Label text="Código Postal" styleClass="form-label"/>
                            <TextField fx:id="codigoPostalField" promptText="28001" styleClass="form-input"/>
                        </VBox>
                    </GridPane>

                    <VBox spacing="8">
                        <Label text="País" styleClass="form-label"/>
                        <ComboBox fx:id="paisCombo" styleClass="form-input" maxWidth="Infinity"/>
                    </VBox>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <CheckBox fx:id="vipCheckBox" text="Cliente VIP" styleClass="checkbox-vip"/>
                    </HBox>

                    <Label fx:id="errorFormLabel" styleClass="error-label" visible="false" wrapText="true"/>

                    <HBox spacing="15" alignment="CENTER_RIGHT">
                        <Button text="Cancelar" styleClass="btn-secondary" onAction="#cerrarModalForm" prefWidth="120"/>
                        <Button text="Guardar" styleClass="btn-submit" onAction="#guardarCliente" prefWidth="120"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </StackPane>

    <!-- MODAL DE DETALLES - CENTRADO Y ALTURA AUTOMÁTICA -->
    <StackPane fx:id="modalDetallesContainer" visible="false" managed="false"
               alignment="CENTER" style="-fx-background-color: rgba(0,0,0,0.6);">
        <VBox styleClass="modal-content" maxWidth="600" maxHeight="-Infinity"
              style="-fx-max-height: 80vh;">
            <HBox styleClass="modal-header" alignment="CENTER_LEFT">
                <Label text="Detalles del Cliente" styleClass="modal-title">
                    <font><Font name="System Bold" size="24"/></font>
                </Label>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="×" styleClass="btn-close" onAction="#cerrarModalDetalles">
                    <font><Font size="28"/></font>
                </Button>
            </HBox>

            <ScrollPane fitToWidth="true" fitToHeight="true" 
                       style="-fx-background-color: white; -fx-background: white;">
                <VBox spacing="20" style="-fx-background-color: white; -fx-padding: 25;">
                    <GridPane hgap="20" vgap="15">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="40"/>
                            <ColumnConstraints percentWidth="60"/>
                        </columnConstraints>

                        <Label text="Nombre Completo:" styleClass="detalle-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <Label fx:id="detallesNombreLabel" styleClass="detalle-valor" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="DNI:" styleClass="detalle-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <Label fx:id="detallesDniLabel" styleClass="detalle-valor" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Email:" styleClass="detalle-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <Label fx:id="detallesEmailLabel" styleClass="detalle-valor" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label text="Teléfono:" styleClass="detalle-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <Label fx:id="detallesTelefonoLabel" styleClass="detalle-valor" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                        <Label text="Dirección:" styleClass="detalle-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                        <Label fx:id="detallesDireccionLabel" styleClass="detalle-valor" wrapText="true" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                        <Label text="Ciudad:" styleClass="detalle-label" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                        <Label fx:id="detallesCiudadLabel" styleClass="detalle-valor" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                        <Label text="Código Postal:" styleClass="detalle-label" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                        <Label fx:id="detallesCodigoPostalLabel" styleClass="detalle-valor" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

                        <Label text="País:" styleClass="detalle-label" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                        <Label fx:id="detallesPaisLabel" styleClass="detalle-valor" GridPane.rowIndex="7" GridPane.columnIndex="1"/>

                        <Label text="Fecha de Registro:" styleClass="detalle-label" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
                        <Label fx:id="detallesFechaRegistroLabel" styleClass="detalle-valor" GridPane.rowIndex="8" GridPane.columnIndex="1"/>

                        <Label text="Estado:" styleClass="detalle-label" GridPane.rowIndex="9" GridPane.columnIndex="0"/>
                        <Label fx:id="detallesEstadoLabel" styleClass="detalle-valor" GridPane.rowIndex="9" GridPane.columnIndex="1"/>

                        <Label text="Reservas Totales:" styleClass="detalle-label" GridPane.rowIndex="10" GridPane.columnIndex="0"/>
                        <Label fx:id="detallesReservasLabel" styleClass="detalle-valor" GridPane.rowIndex="10" GridPane.columnIndex="1"/>
                    </GridPane>

                    <HBox alignment="CENTER">
                        <Button text="Cerrar" styleClass="btn-primary" onAction="#cerrarModalDetalles" prefWidth="150"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </StackPane>
</StackPane>
