<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.hotel.gestion_hotelera.controller.ClienteController"
      style="-fx-background-color: #F5F7FA;"
      spacing="20">
    <padding><Insets top="30" bottom="30" left="30" right="30"/></padding>

    <!-- TOPBAR -->
    <HBox style="-fx-background-color: white; -fx-background-radius: 15;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);"
          alignment="CENTER_LEFT">
        <padding><Insets top="20" bottom="20" left="30" right="30"/></padding>
        <Label text="Gestión de Clientes"
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
    </HBox>

    <!-- BARRA BÚSQUEDA + BOTONES -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <TextField fx:id="txtBuscar"
                   promptText="🔍  Buscar por nombre, apellidos o DNI..."
                   style="-fx-background-radius: 10; -fx-border-radius: 10;
                          -fx-border-color: #E0E0E0; -fx-padding: 10 15 10 15; -fx-font-size: 14px;"
                   prefWidth="400" onKeyReleased="#buscarCliente"/>
        <Button text="+ Nuevo Cliente" onAction="#abrirFormularioNuevo"
                style="-fx-background-color: #3498DB; -fx-text-fill: white;
                       -fx-background-radius: 10; -fx-padding: 10 20 10 20;
                       -fx-font-size: 14px; -fx-cursor: hand;"/>
        <Button text="⭐ Solo VIP" onAction="#filtrarVip"
                style="-fx-background-color: #F39C12; -fx-text-fill: white;
                       -fx-background-radius: 10; -fx-padding: 10 20 10 20;
                       -fx-font-size: 14px; -fx-cursor: hand;"/>
    </HBox>

    <!-- TABLA -->
    <TableView fx:id="tablaClientes" VBox.vgrow="ALWAYS"
               style="-fx-background-radius: 15;
                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);">
        <columns>
            <TableColumn fx:id="colNombre"    text="Nombre"    prefWidth="150"/>
            <TableColumn fx:id="colApellidos" text="Apellidos"  prefWidth="180"/>
            <TableColumn fx:id="colDni"       text="DNI"        prefWidth="110"/>
            <TableColumn fx:id="colEmail"     text="Email"      prefWidth="200"/>
            <TableColumn fx:id="colTelefono"  text="Teléfono"   prefWidth="130"/>
            <TableColumn fx:id="colCiudad"    text="Ciudad"     prefWidth="120"/>
            <TableColumn fx:id="colVip"       text="VIP"        prefWidth="60"/>
            <TableColumn fx:id="colAcciones"  text="Acciones"   prefWidth="120"/>
        </columns>
    </TableView>

</VBox>